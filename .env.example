# Required for live runs.
GEMINI_API_KEY=

# Optional – defaults to gemini-2.5-flash (a currently supported, stable Gemini model).
# Other supported values: gemini-2.0-flash, gemini-1.5-pro, gemini-1.5-flash
GEMINI_MODEL=gemini-2.5-flash

# Optional. Without this key, the agent uses the keyless Google News RSS fallback.
NEWS_API_KEY=

# Set to 'newsapi' if NEWS_API_KEY is provided, otherwise leave as 'rss'.
NEWS_PROVIDER=rss

# Display-only – no email is actually sent. Controls the simulated recipient count shown in the UI.
NEXT_PUBLIC_SIMULATED_RECIPIENT_COUNT=1248
