# Required for live runs. The default model is stable Gemini 2.5 Flash; override if desired.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Optional. Without this key, the agent uses Google News RSS.
NEWS_API_KEY=
NEWS_PROVIDER=rss
# Display-only simulation metadata (no email is actually sent).
NEXT_PUBLIC_SIMULATED_RECIPIENT_COUNT=1248
